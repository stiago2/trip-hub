{
  "buildCommand": "npx nx build web --configuration=production",
  "outputDirectory": "dist/apps/frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://trip-hub-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
