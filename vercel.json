{
  "buildCommand": "npx nx build web --configuration=production",
  "outputDirectory": "dist/apps/frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_RAILWAY_URL/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
